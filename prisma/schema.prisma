generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum InvoiceFormat {
  POOJA_XEROX
  POOJA_ENTERPRISES
}

enum TaxMode {
  CGST_SGST
  IGST
}

enum TemplateItemType {
  FIXED
  METER
  EXTRA_COPY
  TEXT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  SETTINGS_UPDATE
  DUPLICATE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  role          Role      @default(ADMIN)
  image         String?
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id            String           @id @default(cuid())
  profileId     String?
  profile       BusinessProfile? @relation(fields: [profileId], references: [id], onDelete: Restrict)
  companyName   String
  gstin         String?
  state         String
  stateCode     String
  contactPerson String?
  mobile        String?
  email         String?
  branches      CustomerBranch[]
  invoices      Invoice[]
  templates     InvoiceTemplate[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([companyName])
  @@index([gstin])
  @@index([profileId])
}

model CustomerBranch {
  id         String        @id @default(cuid())
  customerId String
  name       String
  address    String
  city       String
  state      String
  stateCode  String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      InvoiceItem[]
  templates  InvoiceTemplate[]
  templateItems InvoiceTemplateItem[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([customerId])
}

model Invoice {
  id            String        @id @default(cuid())
  profileId      String?
  profile        BusinessProfile? @relation(fields: [profileId], references: [id], onDelete: Restrict)
  invoiceNumber String
  invoiceDate   DateTime
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  sourceTemplateId String?
  sourceTemplate   InvoiceTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  billingMonth     String?
  billingPeriodFrom DateTime?
  billingPeriodTo   DateTime?
  billToName        String?
  billToAddress     String?
  billToGstin       String?
  billToState       String?
  billToStateCode   String?
  placeLabel        String?
  machineModel      String?
  poNumber          String?
  taxMode           TaxMode       @default(CGST_SGST)
  subtotal       Decimal       @db.Decimal(12, 2)
  cgstRate       Decimal       @default(9) @db.Decimal(5, 2)
  sgstRate       Decimal       @default(9) @db.Decimal(5, 2)
  igstRate       Decimal       @default(0) @db.Decimal(5, 2)
  cgstAmount     Decimal       @db.Decimal(12, 2)
  sgstAmount     Decimal       @db.Decimal(12, 2)
  igstAmount     Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2)
  grandTotal     Decimal       @db.Decimal(12, 2)
  amountInWords  String
  notes          String?
  status         InvoiceStatus @default(ISSUED)
  paymentStatus  PaymentStatus @default(UNPAID)
  paidAt         DateTime?
  paymentMode    String?
  paymentReference String?
  items          InvoiceItem[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([invoiceDate])
  @@index([customerId])
  @@index([sourceTemplateId])
  @@index([paymentStatus])
  @@index([profileId])
  @@unique([profileId, invoiceNumber])
}

model InvoiceItem {
  id          String         @id @default(cuid())
  invoiceId   String
  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  srNo        Int
  branchId    String?
  branch      CustomerBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  itemType    TemplateItemType @default(FIXED)
  particulars String
  sacCode     String
  uom         String
  startCount  Int?
  endCount    Int?
  freeQty     Decimal?       @db.Decimal(10, 2)
  qty         Decimal        @db.Decimal(10, 2)
  rate        Decimal        @db.Decimal(12, 2)
  amount      Decimal        @db.Decimal(12, 2)

  @@index([invoiceId])
  @@index([branchId])
}

model InvoiceTemplate {
  id              String              @id @default(cuid())
  profileId       String?
  profile         BusinessProfile?    @relation(fields: [profileId], references: [id], onDelete: Restrict)
  customerId      String
  customer        Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name            String
  code            String              @unique
  description     String?
  branchId        String?
  branch          CustomerBranch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  billToName      String
  billToAddress   String
  billToGstin     String?
  billToState     String
  billToStateCode String
  placeLabel      String?
  machineModel    String?
  poNumber        String?
  taxMode         TaxMode             @default(CGST_SGST)
  cgstRate        Decimal             @default(9) @db.Decimal(5, 2)
  sgstRate        Decimal             @default(9) @db.Decimal(5, 2)
  igstRate        Decimal             @default(18) @db.Decimal(5, 2)
  isActive        Boolean             @default(true)
  items           InvoiceTemplateItem[]
  invoices        Invoice[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([customerId])
  @@index([branchId])
  @@index([profileId])
}

model InvoiceTemplateItem {
  id          String           @id @default(cuid())
  templateId  String
  template    InvoiceTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  srNo        Int
  branchId    String?
  branch      CustomerBranch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  itemType    TemplateItemType @default(FIXED)
  particulars String
  sacCode     String           @default("997314")
  uom         String           @default("")
  qty         Decimal          @default(0) @db.Decimal(10, 2)
  rate        Decimal          @default(0) @db.Decimal(12, 2)
  amount      Decimal          @default(0) @db.Decimal(12, 2)
  startCount  Int?
  endCount    Int?
  freeQty     Decimal?         @db.Decimal(10, 2)
  sortOrder   Int              @default(0)

  @@index([templateId])
  @@index([branchId])
}

model BusinessSettings {
  id                String   @id @default(cuid())
  profileId         String?  @unique
  profile           BusinessProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  businessName      String
  businessAddress   String
  gstNumber         String
  email             String?
  contactNumber     String?
  logoUrl           String?
  stampUrl          String?
  signatureUrl      String?
  terms             String
  cgstPercent       Decimal  @default(9) @db.Decimal(5, 2)
  sgstPercent       Decimal  @default(9) @db.Decimal(5, 2)
  footerText        String?
  invoiceHeaderText String   @default("|| SHREE GANESHAY NAMAH ||")
  bankName          String?
  bankAccountNo     String?
  bankBranch        String?
  bankIfsc          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model BusinessProfile {
  id                 String             @id @default(cuid())
  code               String             @unique
  name               String
  invoiceFormat      InvoiceFormat      @default(POOJA_XEROX)
  invoiceNumberFloor Int                @default(632)
  isActive           Boolean            @default(true)
  settings           BusinessSettings?
  customers          Customer[]
  templates          InvoiceTemplate[]
  invoices           Invoice[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model InvoiceDraft {
  id        String   @id @default(cuid())
  userId    String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}
